model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String
  role          UserRole
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  profile       UserProfile?
  properties    Property[]       
  rentalRequests RentalRequest[] 
  reviews       Review[]         

  @@map("users")
}