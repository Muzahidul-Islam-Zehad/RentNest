{
  "compilerOptions": {
    "outDir": "./dist",

    "target": "ES2023",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "strict": true,
    "isolatedModules": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist"]
}